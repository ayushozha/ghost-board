# Ghost Board Configuration
# Copy to .env and fill in your values

# Required: OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Weights & Biases
WANDB_API_KEY=your-wandb-key-here
WANDB_PROJECT=ghost-board

# Optional: Anthropic API Key (for Claude Code in Ralph Loop build layer)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Database (defaults to local SQLite)
DATABASE_URL=sqlite:///outputs/ghost_board.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/ghost_board

# Optional: Webhook URL for notifications
# WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Optional: Server settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
